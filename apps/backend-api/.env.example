# Stylo Protocol — Backend API Environment
# Copy to .env and fill in values

# Server
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Arbitrum
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
DEPLOYER_PRIVATE_KEY=

# Contract Addresses (Arbitrum One)
STYLO_VAULT_ADDRESS=0x
X402_ESCROW_ADDRESS=0x
ELO_REGISTRY_ADDRESS=0x
PRIVACY_LAYER_ADDRESS=0x
OFT_CETES_ADDRESS=0x

# USDC (Arbitrum One)
USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831

# Pyth Network
PYTH_HERMES_URL=https://hermes.pyth.network

# x402 Configuration
X402_MIN_PAYMENT=0.01
X402_MAX_PAYMENT=0.05
X402_FEE_BPS=100

# MCP Server
MCP_SERVER_PORT=4001
MCP_AUTH_SECRET=your-mcp-secret

# Dead-Man Switch
DEAD_MAN_SWITCH_INTERVAL_MS=30000
DEAD_MAN_MAX_DEVIATION_PERCENT=5
DEAD_MAN_EMERGENCY_THRESHOLD=15
DEAD_MAN_ALERT_WEBHOOK=https://hooks.slack.com/services/xxx
