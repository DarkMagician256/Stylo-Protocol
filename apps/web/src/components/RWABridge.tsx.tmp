"use client";

"use client";

import { useState, useEffect } from "react";
import { ArrowRightLeft, ShieldAlert, Globe } from "lucide-react";
import Image from "next/image";

export function RWABridge() {
  const [assets, setAssets] = useState<any[]>([]);

  useEffect(() => {
    fetch("/api/rwa/assets")
      .then((res) => res.json())
      .then((data) => {
        if (data.success) setAssets(data.data.assets);
      })
      .catch(() => { });
  }, []);

  return (
    <div className="p-4 sm:p-6 md:p-10 max-w-6xl mx-auto animate-fade-in-up">
      <div className="flex flex-col md:flex-row justify-between items-start mb-8 sm:mb-10 gap-4">
        <div>
          <h1 className="text-2xl sm:text-3xl font-bold mb-2">Institutional RWA Portal</h1>
          <p className="text-white/50 max-w-2xl text-sm sm:text-base">
            Tokenized Mexican Treasury Bonds (CETES) bridged to Arbitrum via LayerZero V2 OFT Standard.
          </p>
        </div>
        <div className="glass-subtle px-4 py-3 flex items-start sm:items-center max-w-xs text-xs text-amber-300 border-amber-500/30 shrink-0">
          <ShieldAlert className="w-6 h-6 sm:w-8 sm:h-8 mr-3 opacity-80 shrink-0" />
          <p>Requires ISO-20022 compliance and active KYC/AML verification.</p>
        </div>
      </div>

      <div className="glass-card mb-10 sm:mb-12 p-6 sm:p-8">
        <h2 className="text-xl font-bold mb-6 flex items-center">
          <Globe className="w-5 h-5 mr-3 text-indigo-400" />
          LayerZero OFT Transfer
        </h2>

        <div className="flex flex-col md:flex-row items-center justify-between gap-4 sm:gap-6">
          <div className="flex-1 bg-black/40 p-5 sm:p-6 rounded-2xl border border-white/5 w-full">
            <div className="text-sm text-white/50 mb-2">From Network</div>
            <div className="text-base sm:text-lg font-semibold flex items-center">
              <img
                src="https://cryptologos.cc/logos/ethereum-eth-logo.svg?v=035"
                className="w-6 h-6 mr-3 grayscale opacity-70"
                alt="ETH"
              />
              Ethereum Mainnet
            </div>
          </div>

          <div className="bg-white/5 p-4 rounded-full border border-white/10 shrink-0 shadow-[0_0_20px_rgba(99,102,241,0.2)]">
            <ArrowRightLeft className="w-6 h-6 text-indigo-400" />
          </div>

          <div className="flex-1 bg-black/40 p-5 sm:p-6 rounded-2xl border border-white/5 w-full">
            <div className="text-sm text-white/50 mb-2">To Network</div>
            <div className="text-base sm:text-lg font-semibold flex items-center">
              <img
                src="https://cryptologos.cc/logos/arbitrum-arb-logo.svg?v=035"
                className="w-6 h-6 mr-3"
                alt="ARB"
              />
              Arbitrum One
            </div>
          </div>
        </div>

        <div className="mt-8 flex justify-center">
          <button className="btn-primary w-full md:w-auto md:px-16" disabled>
            Bridge Assets (KYC Required)
          </button>
        </div>
      </div>

      <h3 className="text-xl font-bold mb-6">Available CETES Instruments</h3>
      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        {assets.map((asset) => (
          <div
            key={asset.id}
            className="glass border border-white/5 p-6 hover:border-indigo-500/30 transition-colors"
          >
            <div className="flex justify-between items-start mb-4">
              <div>
                <h4 className="text-lg font-bold uppercase tracking-wider">
                  {asset.id.replace(/-/g, " ")}
                </h4>
                <div className="text-sm text-white/40 mt-1 font-mono">ISIN: {asset.isin}</div>
              </div>
              <div className="bg-emerald-500/10 text-emerald-400 font-bold px-3 py-1 rounded text-lg shrink-0">
                {asset.couponRate}%
              </div>
            </div>

            <div className="flex items-center gap-6 text-sm text-white/60 mb-6 flex-wrap">
              <div>
                <span className="block text-xs uppercase tracking-wider text-white/30 mb-1">Maturity</span>
                {new Date(asset.maturityDate).toLocaleDateString()}
              </div>
              <div>
                <span className="block text-xs uppercase tracking-wider text-white/30 mb-1">Available</span>
                ${(asset.available * asset.faceValue).toLocaleString()}
              </div>
            </div>

            <div className="flex space-x-3">
              <button className="btn-glass text-xs py-2 w-full">View Prospectus</button>
              <button className="btn-primary text-xs py-2 w-full">Purchase</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}
