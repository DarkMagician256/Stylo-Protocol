"use client";

import { useState, useEffect } from "react";
import { Terminal, Server, CreditCard } from "lucide-react";

export function Marketplace() {
  const [pricing, setPricing] = useState<any>(null);

  useEffect(() => {
    fetch("/api/x402/pricing")
      .then((res) => res.json())
      .then((data) => {
        if (data.success) setPricing(data.data);
      })
      .catch(() => {});
  }, []);

  return (
    <div className="p-4 sm:p-6 md:p-10 max-w-7xl mx-auto animate-fade-in-up">
      <div className="mb-8 sm:mb-10 text-center">
        <h1 className="text-3xl sm:text-4xl font-bold mb-3 sm:mb-4">x402 Agent Marketplace</h1>
        <p className="text-white/50 max-w-2xl mx-auto text-sm sm:text-base px-2">
          Monetize your AI agents or purchase intelligence feeds via atomic on-chain USDC micropayments natively on
          Arbitrum One.
        </p>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 mb-8 sm:mb-12">
        {/* Endpoints list */}
        <div className="glass-card p-6 sm:p-8 lg:col-span-2">
          <h2 className="text-2xl font-bold mb-6 flex items-center">
            <Server className="w-6 h-6 mr-3 text-indigo-400" />
            Active MCP Endpoints
          </h2>
          <div className="space-y-4">
            {pricing?.endpoints.map((ep: any, i: number) => (
              <div
                key={i}
                className="flex flex-col sm:flex-row justify-between items-start sm:items-center bg-white/5 border border-white/10 p-4 rounded-xl hover:bg-white/10 transition-colors gap-3"
              >
                <div>
                  <div className="font-mono text-cyan-300 font-medium text-sm">{ep.path}</div>
                  <div className="text-sm text-white/50 mt-1">{ep.description}</div>
                </div>
                <div className="flex items-center space-x-3 w-full sm:w-auto">
                  <div className="bg-black/50 px-4 py-2 rounded-lg font-mono text-emerald-400 flex-1 sm:flex-none text-center text-sm">
                    ${ep.price} {pricing.currency}
                  </div>
                  <button className="p-2 bg-indigo-500/20 hover:bg-indigo-500/40 border border-indigo-500/30 rounded-lg text-indigo-200 transition-colors shrink-0">
                    <Terminal className="w-5 h-5" />
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Sidebar */}
        <div className="space-y-6 sm:space-y-8">
          <div className="glass-card p-6 border-indigo-500/20 shadow-[0_0_30px_rgba(99,102,241,0.1)]">
            <h3 className="text-lg font-bold mb-4 flex items-center">
              <CreditCard className="w-5 h-5 mr-3 text-white/70" />
              Escrow Balance
            </h3>
            <div className="text-4xl font-black text-white mb-2">
              2.45 <span className="text-xl text-white/40">USDC</span>
            </div>
            <div className="text-sm text-white/50 mb-6 font-mono">Arbitrum One</div>
            <button className="btn-primary w-full">Top Up Escrow</button>
          </div>

          <div className="glass p-6 text-sm">
            <h4 className="font-bold text-white/90 mb-3 uppercase tracking-wider text-xs">How it works</h4>
            <ol className="list-decimal list-inside space-y-3 text-white/60">
              <li>Deposit USDC into the Escrow contract.</li>
              <li>
                Include{" "}
                <code className="bg-black/50 px-1 py-0.5 rounded text-indigo-300">X-402-Payment</code> header in
                API calls.
              </li>
              <li>Middleware deducts $0.01 directly via Stylus.</li>
              <li>Agent immediately receives 99% of payment.</li>
            </ol>
          </div>
        </div>
      </div>
    </div>
  );
}
