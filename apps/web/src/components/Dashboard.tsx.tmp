"use client";

import { useState, useEffect } from "react";
import { Activity, Brain, TrendingUp, Zap } from "lucide-react";

interface SwarmMetrics {
  totalAgents: number;
  activeAgents: number;
  swarmPnL: number;
  totalVolume: number;
  activeX402Settlements: number;
  averageSharpe: number;
}

interface Agent {
  id: string;
  name: string;
  status: "racing" | "analyzing" | "synthesizing" | "idle" | "executing";
  specialization: string;
  totalPnL: number;
  sharpeRatio: number;
  eloRating: number;
}

export function Dashboard() {
  const [metrics, setMetrics] = useState<SwarmMetrics | null>(null);
  const [agents, setAgents] = useState<Agent[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetch("/api/agents")
      .then((res) => res.json())
      .then((data) => {
        if (data.success) {
          setMetrics(data.data.swarmMetrics);
          setAgents((data.data.agents as Agent[]).sort((a, b) => b.eloRating - a.eloRating));
        }
        setLoading(false);
      })
      .catch((err) => {
        console.error("Failed to fetch dashboard data", err);
        setLoading(false);
      });
  }, []);

  if (loading) {
    return (
      <div className="p-6 md:p-8 max-w-7xl mx-auto">
        <div className="skeleton h-40 sm:h-64 w-full mb-8 rounded-2xl" />
        <div className="skeleton h-64 sm:h-96 w-full rounded-2xl" />
      </div>
    );
  }

  return (
    <div className="p-4 sm:p-6 md:p-10 max-w-7xl mx-auto animate-fade-in-up">
      {/* Header */}
      <div className="mb-8 sm:mb-10 flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div>
          <h1 className="text-2xl sm:text-3xl font-bold mb-2">Global Swarm Dashboard</h1>
          <p className="text-white/50 text-sm sm:text-base">
            Real-time visualization of Stylo's autonomous AI execution layer.
          </p>
        </div>
        <div className="flex items-center space-x-2 text-sm bg-indigo-500/10 text-indigo-300 px-4 py-2 rounded-full border border-indigo-500/20 w-fit">
          <Activity className="w-4 h-4" />
          <span>Live Telemetry</span>
        </div>
      </div>

      {/* Metrics Grid */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-8 sm:mb-12">
        <MetricCard
          title="Total Swarm PnL"
          value={`$${metrics?.swarmPnL.toLocaleString()}`}
          icon={<TrendingUp className="text-emerald-400 w-5 h-5" />}
        />
        <MetricCard
          title="Active Agents"
          value={`${metrics?.activeAgents} / ${metrics?.totalAgents}`}
          icon={<Brain className="text-indigo-400 w-5 h-5" />}
        />
        <MetricCard
          title="30D Volume"
          value={`$${metrics?.totalVolume.toLocaleString()}`}
          icon={<Activity className="text-cyan-400 w-5 h-5" />}
        />
        <MetricCard
          title="x402 / min"
          value={metrics?.activeX402Settlements.toString() ?? "0"}
          icon={<Zap className="text-amber-400 w-5 h-5" />}
        />
      </div>

      {/* Agent Leaderboard */}
      <div className="glass-card overflow-hidden">
        <div className="px-4 sm:px-6 py-4 sm:py-5 border-b border-white/5 flex flex-col sm:flex-row justify-between sm:items-center gap-2 bg-white/5">
          <h2 className="text-lg sm:text-xl font-bold">Top Performing Agents (ELO)</h2>
          <span className="text-xs text-white/40">Powered by On-chain EloRegistry.rs</span>
        </div>

        {/* Desktop table */}
        <div className="hidden sm:block overflow-x-auto">
          <table className="w-full text-left border-collapse">
            <thead>
              <tr className="border-b border-white/10 text-white/50 text-xs uppercase tracking-wider">
                <th className="px-6 py-4 font-medium">Rank</th>
                <th className="px-6 py-4 font-medium">Agent Name</th>
                <th className="px-6 py-4 font-medium">Status</th>
                <th className="px-6 py-4 font-medium hidden lg:table-cell">Specialization</th>
                <th className="px-6 py-4 font-medium text-right">ELO</th>
                <th className="px-6 py-4 font-medium text-right hidden md:table-cell">Sharpe</th>
                <th className="px-6 py-4 font-medium text-right">Total PnL</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-white/5">
              {agents.slice(0, 10).map((agent, i) => (
                <tr key={agent.id} className="hover:bg-white/5 transition-colors group">
                  <td className="px-6 py-4 font-mono text-white/50">#{i + 1}</td>
                  <td className="px-6 py-4 font-medium">
                    <span className="text-white/90 group-hover:text-indigo-300 transition-colors">
                      {agent.name}
                    </span>
                  </td>
                  <td className="px-6 py-4">
                    <div className="flex items-center space-x-2">
                      <span className={`status-dot status-${agent.status}`} />
                      <span className="text-xs capitalize text-white/70">{agent.status}</span>
                    </div>
                  </td>
                  <td className="px-6 py-4 hidden lg:table-cell">
                    <span className="text-xs bg-white/5 px-2 py-1 rounded-md text-white/60">
                      {agent.specialization.replace("_", " ")}
                    </span>
                  </td>
                  <td className="px-6 py-4 text-right font-mono font-medium text-cyan-400">
                    {agent.eloRating}
                  </td>
                  <td className="px-6 py-4 text-right font-mono text-white/70 hidden md:table-cell">
                    {agent.sharpeRatio}
                  </td>
                  <td className="px-6 py-4 text-right font-mono text-emerald-400">
                    +${agent.totalPnL.toLocaleString()}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {/* Mobile card list */}
        <div className="sm:hidden divide-y divide-white/5">
          {agents.slice(0, 10).map((agent, i) => (
            <div key={agent.id} className="p-4 hover:bg-white/5 transition-colors">
              <div className="flex items-center justify-between mb-2">
                <div className="flex items-center space-x-2">
                  <span className="font-mono text-xs text-white/40">#{i + 1}</span>
                  <span className="font-semibold text-white/90">{agent.name}</span>
                </div>
                <div className="flex items-center space-x-1.5">
                  <span className={`status-dot status-${agent.status}`} />
                  <span className="text-xs capitalize text-white/60">{agent.status}</span>
                </div>
              </div>
              <div className="flex justify-between text-xs">
                <span className="font-mono text-cyan-400">ELO {agent.eloRating}</span>
                <span className="font-mono text-emerald-400">+${agent.totalPnL.toLocaleString()}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

function MetricCard({
  title,
  value,
  icon,
}: {
  title: string;
  value: string;
  icon: React.ReactNode;
}) {
  return (
    <div className="glass p-4 sm:p-6 hover:bg-white/5 transition-colors border-glow">
      <div className="flex justify-between items-start mb-3 sm:mb-4">
        <h3 className="text-xs sm:text-sm font-medium text-white/50 leading-tight pr-2">{title}</h3>
        {icon}
      </div>
      <div className="text-2xl sm:text-3xl font-black tracking-tight">{value}</div>
    </div>
  );
}
